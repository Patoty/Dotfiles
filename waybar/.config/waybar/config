{
    "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 25, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    "spacing": 0, // Gaps between modules (4px)
    // Choose the order of the modules
    "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad", "custom/media", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["tray", "mpd", "idle_inhibitor", "pulseaudio", "network", "cpu", "memory", "temperature", "backlight", "keyboard-state", "sway/language", "battery", "battery#bat2", "power-profiles-daemon", "custom/powermenu"],
    // Modules configuration
    "sway/mode": {
        "format": "яБФяДЕ {}"
    },
    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": false,
        "warp-on-scroll": false,
        "format": "{icon}",
        "format-icons": {
            "1": "1 <span font='Font Awesome 5 Free 14'>яВЖ</span>",
            "2": "2 <span font='Font Awesome 5 Free 14'>яГа</span>",
            "3": "3 <span font='Font Awesome 5 Free 14'>яЙй</span>",
            "4": "4 <span font='Font Awesome 5 Free 14'>яДб</span>",
            "5": "5 <span font='Font Awesome 5 Free 14'>яБ╗</span>",
            "6": "6 <span font='Font Awesome 5 Free 14'>яВД</span>",
            "7": "7 <span font='Font Awesome 5 Free 14'>яА╛</span>",
            "8": "8 <span font='Font Awesome 5 Free 14'>яБ┤</span>",
            "9": "9 <span font='Font Awesome 5 Free 14'>яЖ╝</span>",
            //"9": "9 <span font='Font Awesome 5 Free 14'>яАБ</span>",
            "10": "10 <span font='Font Awesome 5 Free 14'>яДа</span>",
            "urgent": "яБк",
            //"focused": "яЖТ",
            "default": "яДС",
			"11": "11",
			"12": "12",
			"13": "13",
			"14": "14",
			"15": "15",
			"16": "16",
			"17": "17",
			"18": "18",
			"19": "19",
        }
    },
    "tray": {
        "icon-size": 20,
        "spacing": 8
    },
    "sway/window": {
        "max-length": 60,
        "tooltip": false
        // "format": "( {} )"
    },
    "keyboard-state": {
        "numlock": true,
        "capslock": true,
        "format": "{name} {icon}",
        "format-icons": {
            "locked": "яАг",
            "unlocked": "яВЬ"
        }
    },
    //"hyprland/mode": {
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    //"hyprland/scratchpad": {
    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", "яЛТ"],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },
    "mpd": {
        "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) т╕и{songPosition}|{queueLength}т╕й {volume}% яАБ",
        "format-disconnected": "Disconnected яАБ",
        "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped яАБ",
        "unknown-tag": "N/A",
        "interval": 2,
        "consume-icons": {
            "on": "яГД "
        },
        "random-icons": {
            "off": "<span color=\"#f53c3c\">яБ┤</span> ",
            "on": "яБ┤ "
        },
        "repeat-icons": {
            "on": "яАЮ "
        },
        "single-icons": {
            "on": "яАЮ1 "
        },
        "state-icons": {
            "paused": "яБМ",
            "playing": "яБЛ"
        },
        "tooltip-format": "MPD (connected)",
        "tooltip-format-disconnected": "MPD (disconnected)"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "яБо",
            "deactivated": "яБ░"
        }
    },
    "tray": {
        // "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        // "timezone": "America/New_York",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "format-alt": "{:%d-%m-%Y}"
    },
    "cpu": {
        "format": "{usage}% яЛЫ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% яГЙ"
    },
    "temperature": {
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        // "format-critical": "{temperatureC}┬░C {icon}",
        "format": "{temperatureC}┬░C {icon}",
        "format-icons": [
            "яЛЛ", // Icon: temperature-empty
            "яЛК", // Icon: temperature-quarter
            "яЛЙ", // Icon: temperature-half
            "яЛИ", // Icon: temperature-three-quarters
            "яЛИ"  // Icon: temperature-full
        ]
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "{percent}% {icon}",
        "format-alt": "{icon}",
        "format-alt-click": "click-left",
        "format-icons": ["юОН", "юПУ", "юПС", "юПП", "юПО", "юПН", "юПК", "юПИ", "юОЫ"],
        "on-scroll-up": "light -A 1",
        "on-scroll-down": "light -U 1",
    },
    "battery": {
        "states": {
            // "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{capacity}% -{power}W {icon}",
        "format-charging": "{capacity}% яЧз",
        "format-plugged": "{capacity}% яЗж",
        "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "format-icons": ["яЙД", "яЙГ", "яЙВ", "яЙБ", "яЙА"]
    },
    "battery#bat2": {
        "bat": "BAT2"
    },
    "network": {
        // "interface": "wlp2*", // (Optional) To force the use of this interface
        //"format-wifi": "{essid} ({signalStrength}%) яЗл",
        "format-wifi": "({signalStrength}%/{bandwidthTotalBytes}) яЗл",
        "format-ethernet": "{bandwidthTotalBytes} яЮЦ",
        "tooltip-format": "{ifname} via {gwaddr} яЮЦ",
        "format-linked": "{ifname} (No IP) яЮЦ",
        "format-disconnected": "Disconnected тЪа",
        "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{volume}% {icon} {format_source}",
        "format-bluetooth": "{volume}% {icon}яКФ {format_source}",
        "format-bluetooth-muted": "яЪй {icon}яКФ {format_source}",
        "format-muted": "яЪй {format_source}",
        "format-source": "{volume}% яД░",
        "format-source-muted": "яД▒",
        "format-icons": {
            "headphone": "яАе",
            "hands-free": "яЦР",
            "headset": "яЦР",
            "phone": "яВХ",
            "portable": "яВХ",
            "car": "яЖ╣",
            "default": ["яАж", "яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },
    "custom/media": {
        "format": "{icon} {}",
        "return-type": "json",
        "max-length": 40,
        "format-icons": {
            "spotify": "яЖ╝",
            "default": "ЁЯОЬ"
        },
        "escape": true,
        "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null" // Script in resources folder
        // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
    },
    "custom/powermenu": {
        "return-type": "json",
        "exec": "$HOME/.config/waybar/modules/powermenu.sh",
        "format": "<span font='Font Awesome 5 Free 9'>{icon}</span>  {}",
        "format-icons": ["яАС"],
        "interval": 3600,
        "escape": true,
        "on-click": "$HOME/.config/wofi/wofi-power.sh"
    },
	"power-profiles-daemon": {
		"format": " {icon} ",
  		"tooltip-format": "Power profile: {profile}\nDriver: {driver}",
  		"tooltip": true,
  		"format-icons": {
  		  "default": "яГз",
  		  "performance": "яГз",
  		  "balanced": "яЙО",
  		  "power-saver": "яБм"
		},
		"on-click": "~/bin/power_profile.sh",
	}
}
