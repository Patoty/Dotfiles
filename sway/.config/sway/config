### Idle configuration
#
# Example configuration:
#
exec swayidle -w \
         timeout 300 'swaylock -f -c 000000 -i $lockscreen' \
         timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
         before-sleep 'swaylock -f -c 000000 -i $lockscreen'

bindsym $mod+Delete exec swaylock -f -c 000000 -i $lockscreen 

# This will lock your screen after 300 seconds of inactivity, then turn off
